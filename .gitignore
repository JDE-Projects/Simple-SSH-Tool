# Runtime data (maps your internal hosts/usernames - keep private)
devices.json

# Pinned SSH host keys (trust-on-first-use store)
known_hosts

# PyInstaller build artifacts
build/
dist/
*.spec

# Python
__pycache__/
*.pyc

# Personal local launcher (not for distribution)
Launch_*.bat

# Optional debug logs (written next to the exe when toggled on)
Debug_Log_*.txt

# Console export files written next to the exe
*_Console_*.txt
